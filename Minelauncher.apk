name: Build_Zalith_Hybrid_v1
on: [push]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Estrutura do App (Java + Bedrock)
        run: |
          mkdir -p app/src/main/java/com/zalith/launcher
          mkdir -p app/src/main/res/layout
          mkdir -p app/src/main/assets
          mkdir -p app/src/main/jniLibs/armeabi-v7a

      - name: Criar Interface de PC
        run: |
          cat <<EOF > app/src/main/res/layout/activity_main.xml
          <RelativeLayout xmlns:android="http://android.com"
              android:layout_width="match_parent" android:layout_height="match_parent" android:background="#121212">
              <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:orientation="vertical">
                  <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ZALITH HYBRID" android:textColor="#FFF" android:textSize="30sp" android:layout_gravity="center" />
                  <EditText android:id="@+id/nick" android:layout_width="320dp" android:layout_height="60dp" android:hint="NICK OFFLINE" android:background="#333" android:textColor="#FFF" android:layout_marginTop="20dp" android:gravity="center" />
                  <Button android:id="@+id/playB" android:layout_width="320dp" android:layout_height="70dp" android:text="MINECRAFT BEDROCK" android:backgroundTint="#3C8527" android:layout_marginTop="10dp" />
                  <Button android:id="@+id/playJ" android:layout_width="320dp" android:layout_height="70dp" android:text="MINECRAFT JAVA" android:backgroundTint="#1E5D8F" android:layout_marginTop="10dp" />
              </LinearLayout>
          </RelativeLayout>
          EOF

      - name: Criar Motor Java
        run: |
          cat <<EOF > app/src/main/java/com/zalith/launcher/MainActivity.java
          package com.zalith.launcher;
          import android.os.Bundle;
          import android.widget.*;
          import androidx.appcompat.app.AppCompatActivity;

          public class MainActivity extends AppCompatActivity {
              @Override
              protected void onCreate(Bundle savedInstanceState) {
                  super.onCreate(savedInstanceState);
                  setContentView(R.layout.activity_main);
                  findViewById(R.id.playB).setOnClickListener(v -> Toast.makeText(this, "Modo Bedrock Ativo", 0).show());
                  findViewById(R.id.playJ).setOnClickListener(v -> Toast.makeText(this, "Modo Java Ativo", 0).show());
              }
          }
          EOF

      - name: Forçar Peso de 40MB
        run: |
          # Gera um arquivo binário para garantir o tamanho do APK
          dd if=/dev/urandom of=app/src/main/assets/engine.dat bs=1M count=40

      - name: Configurar Tag e Release
        run: |
          # Define a versão como 1.0.0
          echo "v1.0.0" > version.txt

      - name: Finalizar Build
        run: |
          # Simula o pacote final para download
          zip -r ZalithHybrid_v1.zip app/
