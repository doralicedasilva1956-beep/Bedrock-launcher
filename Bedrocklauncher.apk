// ==========================================
// 4. LÓGICA PRINCIPAL EM KOTLIN (MainActivity.kt)
// ==========================================

package com.seu.mcbe_launcher

import android.os.Bundle
import android.widget.*
import androidx.appcompat.app.AppCompatActivity

class MainActivity : AppCompatActivity() {

    // Link com a função C++ definida acima
    external fun launchMinecraftNative(username: String, gamePath: String)

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val btnPlay = findViewById<Button>(R.id.btnLaunch)
        val inputUser = findViewById<EditText>(R.id.editUsername)

        btnPlay.setOnClickListener {
            val user = inputUser.text.toString()
            if (user.isNotEmpty()) {
                // Comando para o C++ iniciar o jogo
                launchMinecraftNative(user, applicationInfo.nativeLibraryDir)
                Toast.makeText(this, "Iniciando Minecraft Bedrock como $user", Toast.LENGTH_LONG).show()
            } else {
                Toast.makeText(this, "Por favor, digite um nome!", Toast.LENGTH_SHORT).show()
            }
        }
    }

    companion object {
        init {
            // Carrega o motor C++
            System.loadLibrary("native-lib")
        }
    }
}
