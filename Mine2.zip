package com.zalith.hybrid.launcher;

import android.content.Context;
import android.content.SharedPreferences;
import android.graphics.Color;
import android.graphics.Typeface;
import android.os.Bundle;
import android.text.InputType;
import android.view.Gravity;
import android.view.View;
import android.view.ViewGroup;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
import java.util.ArrayList;
import java.util.List;

/**
 * ZALITH HYBRID LAUNCHER v1.0.0
 * Desenvolvido para suporte Java Edition & Bedrock Edition.
 * Alvo: Android 8.0+ | Arquitetura: armeabi-v7a
 */
public class MainActivity extends AppCompatActivity {

    // Constantes de Configuração
    private static final String PREFS_NAME = "ZalithLauncherPrefs";
    private static final String KEY_LAST_USER = "last_username";
    private static final String KEY_EDITION = "selected_edition";

    // Componentes de UI
    private EditText usernameField;
    private Spinner editionSpinner;
    private Spinner versionSpinner;
    private Button launchButton;
    private TextView statusLog;
    private LinearLayout logsContainer;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        // --- CONSTRUÇÃO DA INTERFACE VIA CÓDIGO (+100 linhas de UI) ---
        ScrollView scrollWrapper = new ScrollView(this);
        scrollWrapper.setFillViewport(true);
        scrollWrapper.setBackgroundColor(Color.parseColor("#121212"));

        LinearLayout rootLayout = new LinearLayout(this);
        rootLayout.setOrientation(LinearLayout.VERTICAL);
        rootLayout.setPadding(50, 50, 50, 50);
        rootLayout.setGravity(Gravity.CENTER_HORIZONTAL);

        // Header - Título do Launcher
        TextView headerTitle = new TextView(this);
        headerTitle.setText("ZALITH HYBRID LAUNCHER");
        headerTitle.setTextColor(Color.parseColor("#3C8527")); // Verde Bedrock
        headerTitle.setTextSize(32f);
        headerTitle.setTypeface(Typeface.DEFAULT_BOLD);
        headerTitle.setPadding(0, 40, 0, 10);
        rootLayout.addView(headerTitle);

        TextView subTitle = new TextView(this);
        subTitle.setText("Versão 1.0.0 - Java & Bedrock");
        subTitle.setTextColor(Color.GRAY);
        subTitle.setPadding(0, 0, 0, 80);
        rootLayout.addView(subTitle);

        // Card de Login
        LinearLayout loginCard = createStyledCard();
        
        TextView labelUser = createLabel("NICKNAME OFFLINE:");
        loginCard.addView(labelUser);

        usernameField = new EditText(this);
        usernameField.setHint("Ex: Player_Zalith");
        usernameField.setHintTextColor(Color.DKGRAY);
        usernameField.setTextColor(Color.WHITE);
        usernameField.setInputType(InputType.TYPE_CLASS_TEXT);
        usernameField.setBackgroundColor(Color.parseColor("#2A2A2A"));
        usernameField.setPadding(30, 30, 30, 30);
        loginCard.addView(usernameField);

        // Seleção de Edição
        loginCard.addView(createLabel("ESCOLHA A EDIÇÃO:"));
        editionSpinner = new Spinner(this);
        String[] editions = {"Minecraft: Bedrock Edition", "Minecraft: Java Edition"};
        setupSpinner(editionSpinner, editions);
        loginCard.addView(editionSpinner);

        // Seleção de Versão
        loginCard.addView(createLabel("VERSÃO DO JOGO:"));
        versionSpinner = new Spinner(this);
        updateVersionSpinner(0); // Padrão Bedrock
        loginCard.addView(versionSpinner);

        rootLayout.addView(loginCard);

        // Listener para mudar as versões dependendo da edição
        editionSpinner.setOnItemSelectedListener(new AdapterView.OnItemSelectedListener() {
            @Override
            public void onItemSelected(AdapterView<?> parent, View view, int position, long id) {
                updateVersionSpinner(position);
            }
            @Override public void onNothingSelected(AdapterView<?> parent) {}
        });

        // Botão de Lançamento
        launchButton = new Button(this);
        launchButton.setText("INICIAR JOGO");
        launchButton.setTextSize(20f);
        launchButton.setTextColor(Color.WHITE);
        launchButton.setBackgroundColor(Color.parseColor("#3C8527"));
        LinearLayout.LayoutParams btnParams = new LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 180);
        btnParams.setMargins(0, 60, 0, 0);
        launchButton.setLayoutParams(btnParams);
        rootLayout.addView(launchButton);

        // Área de Logs de Sistema
        statusLog = new TextView(this);
        statusLog.setText("Aguardando comando...");
        statusLog.setTextColor(Color.DKGRAY);
        statusLog.setPadding(0, 40, 0, 0);
        rootLayout.addView(statusLog);

        scrollWrapper.addView(rootLayout);
        setContentView(scrollWrapper);

        // --- LÓGICA DE FUNCIONAMENTO (+100 linhas de lógica) ---
        loadSavedData();

        launchButton.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                handleLaunch();
            }
        });
    }

    private void handleLaunch() {
        String username = usernameField.getText().toString().trim();
        String edition = editionSpinner.getSelectedItem().toString();
        String version = versionSpinner.getSelectedItem().toString();

        if (username.isEmpty()) {
            Toast.makeText(this, "Erro: Insira um nickname!", Toast.LENGTH_SHORT).show();
            return;
        }

        saveData(username);
        
        statusLog.setText("Status: Preparando motores nativos...");
        launchButton.setEnabled(false);
        launchButton.setText("CARREGANDO...");

        // Simulação de inicialização do motor C++ (armeabi-v7a)
        new android.os.Handler().postDelayed(() -> {
            statusLog.setText("Status: Executando " + version + "...");
            Toast.makeText(MainActivity.this, "Zalith Hybrid: " + edition + " iniciada para " + username, Toast.LENGTH_LONG).show();
            
            // Aqui seria a chamada NDK: launchNativeEngine(username, edition);
            
            launchButton.setEnabled(true);
            launchButton.setText("JOGAR NOVAMENTE");
        }, 3000);
    }

    // Helper: Cria labels de texto estilizadas
    private TextView createLabel(String text) {
        TextView tv = new TextView(this);
        tv.setText(text);
        tv.setTextColor(Color.LTGRAY);
        tv.setTextSize(14f);
        tv.setPadding(0, 30, 0, 10);
        return tv;
    }

    // Helper: Cria containers (cards) para a interface
    private LinearLayout createStyledCard() {
        LinearLayout card = new LinearLayout(this);
        card.setOrientation(LinearLayout.VERTICAL);
        card.setBackgroundColor(Color.parseColor("#1E1E1E"));
        card.setPadding(40, 40, 40, 40);
        LinearLayout.LayoutParams params = new LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT);
        card.setLayoutParams(params);
        return card;
    }

    // Helper: Configura adaptadores de Spinner
    private void setupSpinner(Spinner spinner, String[] items) {
        ArrayAdapter<String> adapter = new ArrayAdapter<>(this, android.R.layout.simple_spinner_item, items);
        adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item);
        spinner.setAdapter(adapter);
        spinner.setBackgroundColor(Color.parseColor("#2A2A2A"));
    }

    private void updateVersionSpinner(int editionIndex) {
        String[] versions;
        if (editionIndex == 0) { // Bedrock
            versions = new String[]{"Bedrock 1.20.73", "Bedrock 1.19.50", "Bedrock 1.16.201", "Bedrock 1.0.0"};
        } else { // Java
            versions = new String[]{"Java 1.20.1", "Java 1.18.2", "Java 1.16.5", "Java 1.12.2", "Java 1.8.9"};
        }
        setupSpinner(versionSpinner, versions);
    }

    // Persistência de Dados (Login Offline)
    private void saveData(String user) {
        SharedPreferences prefs = getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE);
        SharedPreferences.Editor editor = prefs.edit();
        editor.putString(KEY_LAST_USER, user);
        editor.putInt(KEY_EDITION, editionSpinner.getSelectedItemPosition());
        editor.apply();
    }

    private void loadSavedData() {
        SharedPreferences prefs = getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE);
        String lastUser = prefs.getString(KEY_LAST_USER, "");
        int lastEdition = prefs.getInt(KEY_EDITION, 0);

        usernameField.setText(lastUser);
        editionSpinner.setSelection(lastEdition);
    }
}
